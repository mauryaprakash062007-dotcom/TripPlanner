<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:paddingTop="28dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textSize="13sp"
            app:backgroundTint="@color/surface_dark"
            app:cornerRadius="10dp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗂️ Trip History"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View android:layout_width="72dp" android:layout_height="1dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvNoTrips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No trips yet. Plan your first trip!"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="60dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listTripHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@null"
        android:padding="16dp"
        android:clipToPadding="false" />

</LinearLayout>
