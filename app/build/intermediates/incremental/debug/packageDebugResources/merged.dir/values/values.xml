    <string name="app_name">TripPlanner</string>
    <string name="chip_all">All</string>
    <string name="chip_beaches">Beaches</string>
    <string name="chip_cafe">☕ Cafe</string>
    <string name="chip_clubs">💃 Clubs</string>
    <string name="chip_food">Food &amp; Drink</string>
    <string name="chip_nightlife">Nightlife</string>
