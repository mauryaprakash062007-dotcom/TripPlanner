<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Progress header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvPackProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 / 0 packed"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPackEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧳"
            android:textSize="20sp" />

    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/packProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginHorizontal="16dp"
        android:progressTint="@color/accent_teal"
        android:progressBackgroundTint="@color/chip_bg"
        android:max="100"
        android:progress="0" />

    <ListView
        android:id="@+id/listPackItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:padding="16dp"
        android:clipToPadding="false" />

</LinearLayout>
